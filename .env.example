# LLM Provider: "ollama" or "openai"
LLM_PROVIDER=openai

# OpenAI settings (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama settings (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_DIMENSIONS=1536

# Tavily Search API Key
TAVILY_API_KEY=your_key_here

# Pinecone vector store (use a separate index per embedding model/setup)
PINECONE_API_KEY=your_key_here
PINECONE_INDEX_NAME=research-agent-openai-small

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins (defaults to localhost:5173 if unset)
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# Number of search results to retrieve
MAX_SEARCH_RESULTS=5

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=research-agent
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_REDACTION_MODE=redacted_default
LANGSMITH_SAMPLING_RATE=1.0

# Supabase auth + persistence
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated

# RAG orchestration
RAG_STORAGE_BUCKET=rag-resources
RAG_SIGNED_URL_TTL_SECONDS=600

# Inngest (INNGEST_DEV=1 for local dev; set INNGEST_EVENT_KEY in production)
INNGEST_DEV=1
INNGEST_EVENT_KEY=
